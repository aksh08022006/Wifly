{
  "productName": "NetShaper",
  "version": "0.1.0",
  "identifier": "com.netshaper.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src-tauri/dist"
  },
  "app": {
    "windows": [
      {
        "title": "NetShaper - Bandwidth Manager",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "appimage"],
    "msiInstallerUrl": "https://github.com/aksh08022006/Wifly/releases/latest",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "updater": {
    "active": true,
    "endpoints": [
      "https://updates.netshaper.io/releases/{{target}}/{{current_version}}"
    ],
    "dialog": true,
    "pubkey": "YOUR_PUBLIC_KEY_HERE"
  }
}
